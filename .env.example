# ==============================================================================
# Environment Variables for Production Deployment (OPTIONAL)
# ==============================================================================
# 
# ⚠️ IMPORTANTE: Este archivo es SOLO para despliegue en la nube (opcional)
# 
# Para ejecución local (modo por defecto), NO necesitas este archivo.
# Simplemente ejecuta: python ncmds.py
#
# Solo necesitas configurar estas variables si vas a desplegar en:
# - Vercel (vercel.com)
# - Netlify (netlify.com)
# - Otros servicios de hosting
# ==============================================================================

# AI Chat Configuration (Optional - only if using AI features)
LLM7_API_KEY=your-api-key-here

# Flask Configuration (for production only)
# FLASK_ENV=production

# Server Configuration (for traditional deployments like VPS)
# Uncomment and modify if needed for your production environment
# HOST=0.0.0.0
# PORT=8000
