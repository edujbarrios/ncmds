# ==============================================================================
# Environment Variables for Production Deployment (OPTIONAL)
# ==============================================================================
# 
# IMPORTANT: This file is ONLY for optional cloud deployment.
# 
# For local execution (default mode), you do NOT need this file.
# Simply run: python ncmds.py
#
# You only need to configure these variables if you deploy to:
# - Vercel (vercel.com)
# - Netlify (netlify.com)
# - Other hosting services
# ==============================================================================

# AI Chat Configuration (Optional - only if using AI features)
LLM7_API_KEY=your-api-key-here

# Flask Configuration (for production only)
# FLASK_ENV=production

# Server Configuration (for traditional deployments like VPS)
# Uncomment and modify if needed for your production environment
# HOST=0.0.0.0
# PORT=8000
